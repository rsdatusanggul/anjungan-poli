# ============================================================
# ROOT .env.example
# Template konfigurasi environment untuk root project
# ============================================================
# Salin file ini menjadi .env di server, lalu isi nilainya:
#   cp .env.example .env
#   nano .env
# ============================================================

# Token API untuk komunikasi frontend <-> backend
# Generate dengan: openssl rand -hex 32
BACKEND_API_TOKEN=ganti_dengan_token_256bit_acak
