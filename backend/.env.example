# ============================================================
# BACKEND .env.example
# Template konfigurasi environment backend (Go / Gin)
# ============================================================
# Salin file ini menjadi backend/.env di server:
#   cp backend/.env.example backend/.env
#   nano backend/.env
#
# JANGAN pernah commit file backend/.env ke Git!
# ============================================================

# --- Server ---
PORT=8080

# --- Token API (harus sama dengan BACKEND_API_TOKEN di root .env) ---
# Generate dengan: openssl rand -hex 32
API_TOKEN=ganti_dengan_token_256bit_acak

# --- Database SIMRS (Read-Only) ---
# Sesuaikan dengan IP server SIMRS di jaringan rumah sakit
SIMRS_DB_HOST=192.168.x.x
SIMRS_DB_PORT=3306
SIMRS_DB_USER=ganti_user_simrs
SIMRS_DB_PASSWORD=ganti_password_simrs
SIMRS_DB_NAME=ganti_nama_db_simrs

# --- Database Anjungan (Read-Write Lokal di Docker) ---
# Gunakan nama service Docker, bukan localhost
ANJUNGAN_DB_HOST=db
ANJUNGAN_DB_PORT=3306
ANJUNGAN_DB_USER=anjungan_user
ANJUNGAN_DB_PASSWORD=ganti_dengan_password_kuat
ANJUNGAN_DB_NAME=anjungan_db

# --- Redis (di Docker) ---
# Gunakan nama service Docker, bukan localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
